  }

  .room-bg {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
  }

  .top-bar {
    position: absolute;
    right: 30px;
    top: 12px;
    width: 500px;
    height: 200px;
    flex-direction: column;
    align-items: flex-end;
  }

  .coin-pill,
  .checkin-pill,
  .step-pill {
    height: 38px;
    border-radius: 17px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.76);
    background-color: rgba(255, 248, 232, 0.76);
    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-bottom: 7px;
  }

  .coin-pill {
    width: 135px;
    margin-top: 10px;
  }

  .step-pill {
    width: 134px;
    flex-direction: column;
  }

  .checkin-pill {
    width: 110px;
  }

  .mini-icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
    margin-right: 4px;
  }

  .coin-text {
    font-size: 18px;
    color: #6f4118;
  }

  .step-title {
    font-size: 14px;
    color: #6f4118;
    text-align: center;
  }

  .step-sub,
  .checkin-sub,
  .action-stock {
    font-size: 12px;
    color: #a36c31;
    text-align: center;
  }

  .checkin-text {
    font-size: 14px;
    color: #6f4118;
  }

  .pet-zone {
    position: absolute;
    left: 105px;
    top: 220px;
    width: 256px;
    height: 210px;
    overflow: visible;
  }

  .pet-stage {
    position: relative;
    width: 256px;
    height: 256px;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .pet-sprite {
    width: 256px;
    height: 256px;
    object-fit: contain;
  }

  .bow-accessory {
    position: absolute;
    left: 156px;
    top: 60px;
    width: 58px;
    height: 58px;
    object-fit: contain;
  }

  .info-panel {
    position: absolute;
    left: 30px;
    top: 10px;
    width: 220px;
    height: 146px;
    border-radius: 16px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.48);
    background-color: rgba(255, 248, 232, 0.58);
    padding-left: 10px;
    padding-right: 10px;
    padding-top: 8px;
    padding-bottom: 8px;
    flex-direction: column;
  }

  .pet-line {
    width: 196px;
    height: 22px;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }

  .pet-name {
    width: 72px;
    font-size: 18px;
    color: #6f4118;
  }

  .pet-meta {
    width: 122px;
    font-size: 12px;
    color: #8f6338;
    text-align: right;
  }

  .exp-row,
  .status-row {
    width: 196px;
    height: 20px;
    flex-direction: row;
    align-items: center;
  }

  .exp-label,
  .status-label,
  .status-value,
  .exp-text {
    font-size: 13px;
    color: #6f4118;
  }

  .exp-label {
    width: 34px;
  }

  .exp-text {
    width: 44px;
    text-align: right;
  }

  .exp-track {
    width: 116px;
    height: 9px;
    border-radius: 5px;
    background-color: rgba(122, 80, 38, 0.18);
  }

  .exp-fill {
    height: 9px;
    border-radius: 5px;
    background-color: #79c7bd;
  }

  .status-icon {
    width: 16px;
    height: 16px;
    object-fit: contain;
    margin-right: 4px;
  }

  .status-label {
    width: 36px;
  }

  .status-track {
    width: 100px;
    height: 9px;
    border-radius: 5px;
    background-color: rgba(122, 80, 38, 0.16);
  }

  .status-fill {
    height: 9px;
    border-radius: 5px;
  }

  .status-value {
    width: 30px;
    text-align: right;
  }

  .message {
    position: absolute;
    left: 120px;
    top: 250px;
    width: 434px;
    height: 25px;
